<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>日経225分析レポート — {{ date }}</title>
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d28;
    --surface2: #242836;
    --border: #2e3347;
    --accent: #6c8cff;
    --accent2: #ff6c8c;
    --accent3: #6cffa8;
    --text: #e0e4f0;
    --text2: #8b92a8;
    --gold: #ffd700;
    --orange: #ff9f43;
    --red: #ff4d6a;
    --green: #4dff91;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', -apple-system, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }
  .header {
    background: linear-gradient(135deg, #1a1d28 0%, #0f1117 50%, #1a1028 100%);
    border-bottom: 1px solid var(--border);
    padding: 40px 30px;
    text-align: center;
  }
  .header h1 {
    font-size: 1.8em;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .header .date { color: var(--text2); margin-top: 8px; font-size: 0.95em; }
  .container { max-width: 960px; margin: 0 auto; padding: 30px 20px; }

  /* Dashboard cards */
  .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin-bottom: 30px; }
  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    text-align: center;
  }
  .metric-card .label { font-size: 0.8em; color: var(--text2); margin-bottom: 4px; }
  .metric-card .value { font-size: 1.4em; font-weight: 700; }
  .metric-card .change { font-size: 0.85em; margin-top: 4px; }
  .positive { color: var(--green); }
  .negative { color: var(--red); }
  .neutral-val { color: var(--text2); }

  /* Sections */
  .section { margin-bottom: 30px; }
  .section-title {
    font-size: 1.2em;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 12px;
  }
  .card p, .card li { line-height: 1.8; font-size: 0.95em; }
  .card ul { padding-left: 20px; }
  .card li { margin-bottom: 4px; }
  .card h3 { color: var(--orange); font-size: 1em; margin-bottom: 10px; }

  /* Signals */
  .signal { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.8em; font-weight: 600; margin: 2px; }
  .signal-bullish { background: rgba(77,255,145,0.15); color: var(--green); }
  .signal-bearish { background: rgba(255,77,106,0.15); color: var(--red); }
  .signal-info { background: rgba(108,140,255,0.15); color: var(--accent); }

  /* Prediction box */
  .prediction-box {
    background: var(--surface);
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
  }
  .prediction-direction { font-size: 1.5em; font-weight: 700; margin: 10px 0; }
  .confidence-badge {
    display: inline-block;
    padding: 2px 12px;
    border-radius: 12px;
    font-size: 0.8em;
    font-weight: 600;
  }
  .conf-high { background: rgba(77,255,145,0.2); color: var(--green); }
  .conf-medium { background: rgba(255,159,67,0.2); color: var(--orange); }
  .conf-low { background: rgba(255,77,106,0.2); color: var(--red); }

  /* Risk events */
  .risk-table { width: 100%; border-collapse: collapse; font-size: 0.9em; }
  .risk-table th { background: var(--surface2); color: var(--accent); padding: 8px 12px; text-align: left; font-weight: 600; }
  .risk-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); }

  /* Contradiction warning */
  .contradiction {
    background: rgba(255,77,106,0.08);
    border: 1px solid rgba(255,77,106,0.3);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 12px;
  }
  .contradiction h3 { color: var(--red); }

  /* Accuracy stats */
  .accuracy-bar {
    background: var(--surface2);
    border-radius: 6px;
    height: 8px;
    overflow: hidden;
    margin: 8px 0;
  }
  .accuracy-fill { height: 100%; border-radius: 6px; background: linear-gradient(90deg, var(--accent), var(--accent3)); }

  /* Beginner */
  .beginner-box {
    background: linear-gradient(135deg, rgba(108,140,255,0.08), rgba(108,255,168,0.08));
    border: 1px solid rgba(108,140,255,0.2);
    border-radius: 10px;
    padding: 20px;
  }
  .beginner-box h3 { color: var(--accent); margin-bottom: 10px; }

  /* Data quality */
  .quality-indicator { font-size: 0.8em; color: var(--text2); text-align: right; margin-top: 20px; }

  /* Footer */
  .footer { text-align: center; padding: 30px; color: var(--text2); font-size: 0.8em; border-top: 1px solid var(--border); margin-top: 30px; }

  @media (max-width: 640px) {
    .dashboard { grid-template-columns: repeat(2, 1fr); }
    .header h1 { font-size: 1.4em; }
    .container { padding: 20px 12px; }
  }
</style>
</head>
<body>

<div class="header">
  <h1>日経225 毎日分析レポート</h1>
  <div class="date">{{ date }} | 生成時刻: {{ generated_at }}</div>
</div>

<div class="container">

  <!-- Headline -->
  {% if analysis.headline_ja %}
  <div class="card" style="border-left: 3px solid var(--accent); margin-bottom: 24px;">
    <p style="font-size: 1.15em; font-weight: 600;">{{ analysis.headline_ja }}</p>
  </div>
  {% endif %}

  <!-- Dashboard -->
  <div class="dashboard">
    {% if nikkei %}
    <div class="metric-card">
      <div class="label">日経225</div>
      <div class="value">{{ "{:,.0f}".format(nikkei.close|default(0)) }}</div>
      <div class="change {% if nikkei.change_pct|default(0) >= 0 %}positive{% else %}negative{% endif %}">
        {{ "{:+.2f}".format(nikkei.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}

    {% if fx.usdjpy %}
    <div class="metric-card">
      <div class="label">USD/JPY</div>
      <div class="value">{{ "{:.2f}".format(fx.usdjpy.close|default(0)) }}</div>
      <div class="change {% if fx.usdjpy.change_pct|default(0) >= 0 %}positive{% else %}negative{% endif %}">
        {{ "{:+.2f}".format(fx.usdjpy.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}

    {% if market_data.sp500 %}
    <div class="metric-card">
      <div class="label">S&amp;P 500</div>
      <div class="value">{{ "{:,.0f}".format(market_data.sp500.close|default(0)) }}</div>
      <div class="change {% if market_data.sp500.change_pct|default(0) >= 0 %}positive{% else %}negative{% endif %}">
        {{ "{:+.2f}".format(market_data.sp500.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}

    {% if market_data.vix %}
    <div class="metric-card">
      <div class="label">VIX</div>
      <div class="value">{{ "{:.1f}".format(market_data.vix.close|default(0)) }}</div>
      <div class="change {% if market_data.vix.change_pct|default(0) >= 0 %}negative{% else %}positive{% endif %}">
        {{ "{:+.2f}".format(market_data.vix.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}

    {% if commodities.wti_oil %}
    <div class="metric-card">
      <div class="label">WTI原油</div>
      <div class="value">${{ "{:.1f}".format(commodities.wti_oil.close|default(0)) }}</div>
      <div class="change {% if commodities.wti_oil.change_pct|default(0) >= 0 %}positive{% else %}negative{% endif %}">
        {{ "{:+.2f}".format(commodities.wti_oil.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}

    {% if commodities.gold %}
    <div class="metric-card">
      <div class="label">金</div>
      <div class="value">${{ "{:,.0f}".format(commodities.gold.close|default(0)) }}</div>
      <div class="change {% if commodities.gold.change_pct|default(0) >= 0 %}positive{% else %}negative{% endif %}">
        {{ "{:+.2f}".format(commodities.gold.change_pct|default(0)) }}%
      </div>
    </div>
    {% endif %}
  </div>

  <!-- Summary -->
  {% if analysis.summary_ja %}
  <div class="section">
    <div class="section-title">本日の総括</div>
    <div class="card">
      <p>{{ analysis.summary_ja }}</p>
    </div>
  </div>
  {% endif %}

  <!-- Technical Analysis -->
  {% if technical %}
  <div class="section">
    <div class="section-title">テクニカル分析</div>

    <div class="dashboard" style="margin-bottom: 12px;">
      {% if technical.rsi %}
      <div class="metric-card">
        <div class="label">RSI (14)</div>
        <div class="value {% if technical.rsi.zone == 'overbought' %}negative{% elif technical.rsi.zone == 'oversold' %}positive{% else %}neutral-val{% endif %}">
          {{ technical.rsi.value|default('N/A') }}
        </div>
        <div class="change neutral-val">{{ technical.rsi.zone|default('') }}</div>
      </div>
      {% endif %}

      {% if technical.macd %}
      <div class="metric-card">
        <div class="label">MACD</div>
        <div class="value {% if technical.macd.histogram|default(0) >= 0 %}positive{% else %}negative{% endif %}">
          {{ technical.macd.histogram|default('N/A') }}
        </div>
        <div class="change neutral-val">{{ technical.macd.crossover|default('none') }}</div>
      </div>
      {% endif %}

      {% if technical.moving_averages %}
      <div class="metric-card">
        <div class="label">MA5 / MA25</div>
        <div class="value" style="font-size: 1em;">
          {{ technical.moving_averages.ma5|default('N/A') }} / {{ technical.moving_averages.ma25|default('N/A') }}
        </div>
        <div class="change neutral-val">
          {% if technical.moving_averages.golden_cross %}ゴールデンクロス{% elif technical.moving_averages.death_cross %}デッドクロス{% else %}—{% endif %}
        </div>
      </div>
      {% endif %}

      {% if technical.bollinger_bands %}
      <div class="metric-card">
        <div class="label">ボリンジャー位置</div>
        <div class="value" style="font-size: 1em;">{{ technical.bollinger_bands.position|default('N/A') }}</div>
        <div class="change neutral-val">幅: {{ technical.bollinger_bands.band_width_pct|default('N/A') }}%</div>
      </div>
      {% endif %}
    </div>

    {% if technical.signals %}
    <div class="card">
      <h3>シグナル</h3>
      {% for sig in technical.signals %}
      <span class="signal signal-{{ sig.type }}">{{ sig.detail }}</span>
      {% endfor %}
    </div>
    {% endif %}

    {% if analysis.technical_summary_ja %}
    <div class="card">
      <p>{{ analysis.technical_summary_ja }}</p>
    </div>
    {% endif %}
  </div>
  {% endif %}

  <!-- Key Drivers -->
  {% if analysis.drivers %}
  <div class="section">
    <div class="section-title">主要な駆動要因</div>
    {% for driver in analysis.drivers %}
    <div class="card" style="border-left: 3px solid {% if driver.impact == 'positive' %}var(--green){% elif driver.impact == 'negative' %}var(--red){% else %}var(--text2){% endif %};">
      <h3>{{ driver.factor_ja }}</h3>
      <p>{{ driver.detail_ja }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Contradictions -->
  {% if contradiction_flags %}
  <div class="section">
    <div class="section-title">矛盾・注意点</div>
    {% for flag in contradiction_flags %}
    <div class="contradiction">
      <h3>{{ flag.type }}</h3>
      <p>{{ flag.detail_ja }}</p>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Continuity -->
  {% if analysis.continuity_ja %}
  <div class="section">
    <div class="section-title">過去分析との連続性</div>
    <div class="card">
      <p>{{ analysis.continuity_ja }}</p>
    </div>
  </div>
  {% endif %}

  <!-- Prediction -->
  {% if analysis.prediction %}
  <div class="section">
    <div class="section-title">明日の予測</div>
    <div class="prediction-box">
      <div class="prediction-direction">
        {% set dir_map = {"strong_up": "強い上昇", "slight_up": "小幅上昇", "flat": "横ばい", "slight_down": "小幅下落", "strong_down": "強い下落"} %}
        {% set dir_color = {"strong_up": "positive", "slight_up": "positive", "flat": "neutral-val", "slight_down": "negative", "strong_down": "negative"} %}
        <span class="{{ dir_color.get(analysis.prediction.direction, 'neutral-val') }}">
          {{ dir_map.get(analysis.prediction.direction, analysis.prediction.direction) }}
        </span>
      </div>
      <div>
        {% set conf_class = {"high": "conf-high", "medium": "conf-medium", "low": "conf-low"} %}
        <span class="confidence-badge {{ conf_class.get(analysis.prediction.confidence, 'conf-low') }}">
          置信度: {{ analysis.prediction.confidence|default('N/A') }}
        </span>
      </div>
      <p style="margin-top: 14px; color: var(--text2); font-size: 0.9em;">{{ analysis.prediction.reasoning_ja|default('') }}</p>
      {% if analysis.prediction.risk_factors_ja %}
      <p style="margin-top: 8px; color: var(--text2); font-size: 0.85em;">
        リスク: {{ analysis.prediction.risk_factors_ja|join(' / ') }}
      </p>
      {% endif %}
    </div>

    <!-- Prediction accuracy -->
    {% if prediction_accuracy and prediction_accuracy.total > 0 %}
    <div class="card" style="margin-top: 12px;">
      <h3>過去の予測精度</h3>
      <div class="accuracy-bar">
        <div class="accuracy-fill" style="width: {{ prediction_accuracy.accuracy_pct|default(0) }}%;"></div>
      </div>
      <p style="font-size: 0.85em; color: var(--text2);">
        方向一致率: {{ prediction_accuracy.accuracy_pct|default('N/A') }}%
        ({{ prediction_accuracy.correct }}/{{ prediction_accuracy.total }}回)
      </p>
    </div>
    {% endif %}

    <!-- Previous prediction verification -->
    {% if prediction_verification %}
    <div class="card" style="margin-top: 12px;">
      <h3>前日予測の検証</h3>
      <p>
        予測: {{ prediction_verification.predicted|default('N/A') }} →
        実際: {{ prediction_verification.actual|default('N/A') }}
        ({{ "{:+.2f}".format(prediction_verification.actual_change_pct|default(0)) }}%)
        —
        {% if prediction_verification.result == 'correct' %}
        <span class="positive">的中</span>
        {% elif prediction_verification.result == 'partial' %}
        <span style="color: var(--orange);">部分的中</span>
        {% else %}
        <span class="negative">外れ</span>
        {% endif %}
      </p>
    </div>
    {% endif %}
  </div>
  {% endif %}

  <!-- Risk Events -->
  {% if analysis.risk_events %}
  <div class="section">
    <div class="section-title">リスクイベントカレンダー</div>
    <div class="card" style="padding: 0; overflow: hidden;">
      <table class="risk-table">
        <thead>
          <tr><th>日付</th><th>イベント</th><th>予想される影響</th></tr>
        </thead>
        <tbody>
          {% for event in analysis.risk_events %}
          <tr>
            <td>{{ event.date }}</td>
            <td>{{ event.event_ja }}</td>
            <td>{{ event.impact_ja }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  <!-- Beginner Lesson -->
  {% if analysis.beginner_lesson or (analysis.beginner_topic_hint_ja is defined and analysis.beginner_topic_hint_ja) %}
  <div class="section">
    <div class="section-title">初心者コーナー</div>
    <div class="beginner-box">
      {% if analysis.beginner_lesson %}
      <h3>{{ analysis.beginner_lesson.topic_ja|default('今日のトピック') }}</h3>
      <p>{{ analysis.beginner_lesson.explanation_ja|default('') }}</p>
      {% else %}
      <h3>{{ analysis.beginner_topic_hint_ja }}</h3>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- Data Quality -->
  <div class="quality-indicator">
    データ完全度: {{ data_quality.completeness_pct|default('N/A') }}%
    {% if data_quality.errors %}
    | エラー: {{ data_quality.errors|length }}件
    {% endif %}
  </div>

</div>

<div class="footer">
  日経225毎日分析レポート — AI自動生成<br>
  ※ 本レポートは投資助言ではありません。投資判断はご自身の責任でお願いいたします。
</div>

</body>
</html>
